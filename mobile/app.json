{
  "expo": {
    "name": "Nyumba360",
    "slug": "nyumba360",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nyumba360.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to take photos of properties and documents.",
        "NSPhotoLibraryUsageDescription": "This app uses photo library to select images of properties.",
        "NSLocationWhenInUseUsageDescription": "This app uses location to show nearby properties."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.nyumba360.app",
      "versionCode": 1,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Nyumba360 to access your camera"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Nyumba360 to access your photos"
        }
      ],
      [
        "expo-location",
        {
          "locationPermission": "Allow Nyumba360 to access your location"
        }
      ]
    ],
    "owner": "WRalak",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/update",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    }
  }
}
