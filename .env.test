# =============================================================================
# NYUMBA360 ENVIRONMENT VARIABLES - TESTING
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=test
PORT=5003
HOST=localhost

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_URI=postgresql://neondb_owner:****************@ep-fragrant-term-antif9g7-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DB_NAME=neondb
DB_MAX_CONNECTIONS=5
DB_CONNECTION_TIMEOUT=5000

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET=test_jwt_secret_key_for_testing_only
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=24h

# =============================================================================
# M-PESA DARAJA API CONFIGURATION (Mock for Testing)
# =============================================================================
MPESA_CONSUMER_KEY=test_mpesa_consumer_key
MPESA_CONSUMER_SECRET=test_mpesa_consumer_secret
MPESA_PASSKEY=test_mpesa_passkey
MPESA_SHORTCODE=174379

# M-Pesa Callback URLs (Test URLs)
MPESA_CALLBACK_URL=http://localhost:5003/api/payments/mpesa/callback
MPESA_RESULT_URL=http://localhost:5003/api/payments/mpesa/result
MPESA_QUEUE_TIMEOUT_URL=http://localhost:5003/api/payments/mpesa/timeout
MPESA_ENVIRONMENT=sandbox

# =============================================================================
# EMAIL CONFIGURATION (Mock for Testing)
# =============================================================================
EMAIL_SERVICE=mock
EMAIL_API_KEY=test_email_api_key
EMAIL_FROM=test@nyumba360.co.ke
EMAIL_FROM_NAME=Nyumba360 Test

# =============================================================================
# SMS CONFIGURATION (Mock for Testing)
# =============================================================================
AFRICASTALKING_USERNAME=test_africastalking_username
AFRICASTALKING_API_KEY=test_africastalking_api_key
AFRICASTALKING_SENDER=Nyumba360Test

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_PATH=./test-uploads
MAX_FILE_SIZE=1048576
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:19006
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000
SESSION_SECRET=test_session_secret_for_testing_only
SESSION_MAX_AGE=3600000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=error
LOG_FILE=./logs/test.log

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
REACT_APP_API_URL=http://localhost:5003/api
REACT_APP_MOCK_API=true
REACT_APP_ENVIRONMENT=test
GOOGLE_MAPS_API_KEY=test_google_maps_api_key

# =============================================================================
# MOBILE APP CONFIGURATION
# =============================================================================
EXPO_PUBLIC_API_URL=http://localhost:5003/api
EXPO_PUBLIC_MOCK_API=true
EXPO_PUSH_NOTIFICATION_KEY=test_expo_push_key

# =============================================================================
# AI CONFIGURATION (Mock for Testing)
# =============================================================================
OPENAI_API_KEY=test_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo
ML_MODEL_PATH=./test-models
ML_CONFIDENCE_THRESHOLD=0.5

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION (Test/Sandbox)
# =============================================================================
STRIPE_PUBLISHABLE_KEY=pk_test_test_stripe_key
STRIPE_SECRET_KEY=sk_test_test_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_test_webhook_secret

PAYPAL_CLIENT_ID=test_paypal_client_id
PAYPAL_CLIENT_SECRET=test_paypal_client_secret
PAYPAL_MODE=sandbox

# =============================================================================
# SOCIAL LOGIN CONFIGURATION (Test)
# =============================================================================
GOOGLE_CLIENT_ID=test_google_client_id
GOOGLE_CLIENT_SECRET=test_google_client_secret

FACEBOOK_APP_ID=test_facebook_app_id
FACEBOOK_APP_SECRET=test_facebook_app_secret

# =============================================================================
# ANALYTICS CONFIGURATION (Disabled for Testing)
# =============================================================================
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
TEST_DATABASE_URL=mongodb://localhost:27017/nyumba360_test
TEST_JWT_SECRET=test_jwt_secret
TEST_EMAIL_SERVICE=mock

# Test Data Configuration
GENERATE_TEST_DATA=true
TEST_DATA_SEED=12345
CLEANUP_AFTER_TESTS=true

# =============================================================================
# FEATURE FLAGS (All Enabled for Testing)
# =============================================================================
ENABLE_AI_FEATURES=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=false
ENABLE_SOCIAL_LOGIN=true
ENABLE_INTERNATIONAL_PAYMENTS=true

# =============================================================================
# BUSINESS CONFIGURATION
# =============================================================================
COMPANY_NAME=Nyumba360 Test
COMPANY_EMAIL=test@nyumba360.co.ke
COMPANY_PHONE=+254700000000
COMPANY_ADDRESS=Nairobi, Kenya (Test)
DEFAULT_CURRENCY=KES
DEFAULT_LANGUAGE=en
TIMEZONE=Africa/Nairobi
DATE_FORMAT=YYYY-MM-DD

# =============================================================================
# COMMISSION RATES
# =============================================================================
AGENT_COMMISSION_RATE=0.10
PROPERTY_MANAGER_COMMISSION_RATE=0.05

# =============================================================================
# TESTING SPECIFIC
# =============================================================================
DEBUG=nyumba360:test:*
HOT_RELOAD=false
MOCK_DATA=true

# Test Database Options
DB_DROP_BEFORE_TESTS=true
DB_SEED_AFTER_DROP=true

# Test Coverage
COVERAGE_REPORT=true
COVERAGE_THRESHOLD=80

# Test Performance
TEST_TIMEOUT=30000
SLOW_TEST_THRESHOLD=5000

# Mock Services
MOCK_MPESA=true
MOCK_EMAIL=true
MOCK_SMS=true
MOCK_AI=true
MOCK_FILE_UPLOAD=true
