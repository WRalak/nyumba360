# =============================================================================
# NYUMBA360 ENVIRONMENT VARIABLES - STAGING
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=staging
PORT=5002
HOST=0.0.0.0

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Staging
POSTGRES_URI=postgresql://neondb_owner:****************@ep-fragrant-term-antif9g7-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DB_NAME=neondb
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT=10000

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET=staging_jwt_secret_key_change_this_for_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# M-PESA DARAJA API CONFIGURATION
# =============================================================================
MPESA_CONSUMER_KEY=staging_mpesa_consumer_key
MPESA_CONSUMER_SECRET=staging_mpesa_consumer_secret
MPESA_PASSKEY=staging_mpesa_passkey
MPESA_SHORTCODE=174379

# M-Pesa Callback URLs (Staging URLs)
MPESA_CALLBACK_URL=https://staging-api.nyumba360.co.ke/api/payments/mpesa/callback
MPESA_RESULT_URL=https://staging-api.nyumba360.co.ke/api/payments/mpesa/result
MPESA_QUEUE_TIMEOUT_URL=https://staging-api.nyumba360.co.ke/api/payments/mpesa/timeout
MPESA_ENVIRONMENT=sandbox

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=staging_sendgrid_api_key
EMAIL_FROM=noreply@staging.nyumba360.co.ke
EMAIL_FROM_NAME=Nyumba360 Staging

# =============================================================================
# SMS CONFIGURATION
# =============================================================================
AFRICASTALKING_USERNAME=staging_africastalking_username
AFRICASTALKING_API_KEY=staging_africastalking_api_key
AFRICASTALKING_SENDER=Nyumba360Test

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# AWS S3 Staging
AWS_ACCESS_KEY_ID=staging_aws_access_key
AWS_SECRET_ACCESS_KEY=staging_aws_secret_key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=nyumba360-uploads-staging

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://nyumba360-redis-staging:6379
REDIS_PASSWORD=staging_redis_password

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
CORS_ORIGIN=https://staging.nyumba360.co.ke,https://staging-app.nyumba360.co.ke
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
SESSION_SECRET=staging_session_secret_change_this_for_production
SESSION_MAX_AGE=3600000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
NEW_RELIC_LICENSE_KEY=staging_new_relic_license_key
NEW_RELIC_APP_NAME=Nyumba360-Staging
SENTRY_DSN=staging_sentry_dsn

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
REACT_APP_API_URL=https://staging-api.nyumba360.co.ke/api
REACT_APP_MOCK_API=false
REACT_APP_ENVIRONMENT=staging
GOOGLE_MAPS_API_KEY=staging_google_maps_api_key

# =============================================================================
# MOBILE APP CONFIGURATION
# =============================================================================
EXPO_PUBLIC_API_URL=https://staging-api.nyumba360.co.ke/api
EXPO_PUBLIC_MOCK_API=false
EXPO_PUSH_NOTIFICATION_KEY=staging_expo_push_key

# =============================================================================
# AI CONFIGURATION
# =============================================================================
OPENAI_API_KEY=staging_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo
ML_MODEL_PATH=./models
ML_CONFIDENCE_THRESHOLD=0.8

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION
# =============================================================================
STRIPE_PUBLISHABLE_KEY=pk_test_staging_stripe_key
STRIPE_SECRET_KEY=sk_test_staging_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_staging_webhook_secret

PAYPAL_CLIENT_ID=staging_paypal_client_id
PAYPAL_CLIENT_SECRET=staging_paypal_client_secret
PAYPAL_MODE=sandbox

# =============================================================================
# SOCIAL LOGIN CONFIGURATION
# =============================================================================
GOOGLE_CLIENT_ID=staging_google_client_id
GOOGLE_CLIENT_SECRET=staging_google_client_secret

FACEBOOK_APP_ID=staging_facebook_app_id
FACEBOOK_APP_SECRET=staging_facebook_app_secret

# =============================================================================
# ANALYTICS CONFIGURATION
# =============================================================================
GOOGLE_ANALYTICS_ID=GA-STAGING-XXXXXXXXX
MIXPANEL_TOKEN=staging_mixpanel_token

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_SCHEDULE=0 3 * * *
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_PROVIDER=aws_s3
BACKUP_BUCKET=nyumba360-backups-staging

# =============================================================================
# STAGING CONFIGURATION
# =============================================================================
SSL_CERT_PATH=/etc/ssl/certs/staging.nyumba360.crt
SSL_KEY_PATH=/etc/ssl/private/staging.nyumba360.key
DOMAIN=staging.nyumba360.co.ke
PROTOCOL=https
CDN_URL=https://staging-cdn.nyumba360.co.ke

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_AI_FEATURES=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_SOCIAL_LOGIN=true
ENABLE_INTERNATIONAL_PAYMENTS=false

# =============================================================================
# BUSINESS CONFIGURATION
# =============================================================================
COMPANY_NAME=Nyumba360 Staging
COMPANY_EMAIL=staging@nyumba360.co.ke
COMPANY_PHONE=+254700000000
COMPANY_ADDRESS=Nairobi, Kenya (Staging)
DEFAULT_CURRENCY=KES
DEFAULT_LANGUAGE=en
TIMEZONE=Africa/Nairobi
DATE_FORMAT=YYYY-MM-DD

# =============================================================================
# COMMISSION RATES
# =============================================================================
AGENT_COMMISSION_RATE=0.10
PROPERTY_MANAGER_COMMISSION_RATE=0.05

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
TEST_DATABASE_URL=mongodb://localhost:27017/nyumba360_test
TEST_JWT_SECRET=test_jwt_secret
TEST_EMAIL_SERVICE=mock

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
DEBUG=nyumba360:staging:*
HOT_RELOAD=false
MOCK_DATA=false
