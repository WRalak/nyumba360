# =============================================================================
# NYUMBA360 ENVIRONMENT VARIABLES - PRODUCTION
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=production
PORT=5001
HOST=0.0.0.0

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# MongoDB Atlas Production
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nyumba360_prod?retryWrites=true&w=majority
DB_NAME=nyumba360_prod
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=10000

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET=super_secure_production_jwt_secret_change_this_immediately
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# M-PESA DARAJA API CONFIGURATION
# =============================================================================
MPESA_CONSUMER_KEY=production_mpesa_consumer_key
MPESA_CONSUMER_SECRET=production_mpesa_consumer_secret
MPESA_PASSKEY=production_mpesa_passkey
MPESA_SHORTCODE=your_production_shortcode

# M-Pesa Callback URLs (Production URLs)
MPESA_CALLBACK_URL=https://api.nyumba360.co.ke/api/payments/mpesa/callback
MPESA_RESULT_URL=https://api.nyumba360.co.ke/api/payments/mpesa/result
MPESA_QUEUE_TIMEOUT_URL=https://api.nyumba360.co.ke/api/payments/mpesa/timeout
MPESA_ENVIRONMENT=live

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=production_sendgrid_api_key
EMAIL_FROM=noreply@nyumba360.co.ke
EMAIL_FROM_NAME=Nyumba360

# =============================================================================
# SMS CONFIGURATION
# =============================================================================
AFRICASTALKING_USERNAME=production_africastalking_username
AFRICASTALKING_API_KEY=production_africastalking_api_key
AFRICASTALKING_SENDER=Nyumba360

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# AWS S3 Production
AWS_ACCESS_KEY_ID=production_aws_access_key
AWS_SECRET_ACCESS_KEY=production_aws_secret_key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=nyumba360-uploads-prod

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://nyumba360-redis:6379
REDIS_PASSWORD=production_redis_password

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
CORS_ORIGIN=https://nyumba360.co.ke,https://app.nyumba360.co.ke
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
SESSION_SECRET=super_secure_production_session_secret_change_this_immediately
SESSION_MAX_AGE=3600000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=warn
LOG_FILE=./logs/app.log

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
NEW_RELIC_LICENSE_KEY=production_new_relic_license_key
NEW_RELIC_APP_NAME=Nyumba360-Production
SENTRY_DSN=production_sentry_dsn

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
REACT_APP_API_URL=https://api.nyumba360.co.ke/api
REACT_APP_MOCK_API=false
REACT_APP_ENVIRONMENT=production
GOOGLE_MAPS_API_KEY=production_google_maps_api_key

# =============================================================================
# MOBILE APP CONFIGURATION
# =============================================================================
EXPO_PUBLIC_API_URL=https://api.nyumba360.co.ke/api
EXPO_PUBLIC_MOCK_API=false
EXPO_PUSH_NOTIFICATION_KEY=production_expo_push_key

# =============================================================================
# AI CONFIGURATION
# =============================================================================
OPENAI_API_KEY=production_openai_api_key
OPENAI_MODEL=gpt-4
ML_MODEL_PATH=./models
ML_CONFIDENCE_THRESHOLD=0.85

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION
# =============================================================================
STRIPE_PUBLISHABLE_KEY=pk_live_production_stripe_key
STRIPE_SECRET_KEY=sk_live_production_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_production_webhook_secret

PAYPAL_CLIENT_ID=production_paypal_client_id
PAYPAL_CLIENT_SECRET=production_paypal_client_secret
PAYPAL_MODE=live

# =============================================================================
# SOCIAL LOGIN CONFIGURATION
# =============================================================================
GOOGLE_CLIENT_ID=production_google_client_id
GOOGLE_CLIENT_SECRET=production_google_client_secret

FACEBOOK_APP_ID=production_facebook_app_id
FACEBOOK_APP_SECRET=production_facebook_app_secret

# =============================================================================
# ANALYTICS CONFIGURATION
# =============================================================================
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
MIXPANEL_TOKEN=production_mixpanel_token

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_SCHEDULE=0 2 * * *
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_PROVIDER=aws_s3
BACKUP_BUCKET=nyumba360-backups-prod

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================
SSL_CERT_PATH=/etc/ssl/certs/nyumba360.crt
SSL_KEY_PATH=/etc/ssl/private/nyumba360.key
DOMAIN=nyumba360.co.ke
PROTOCOL=https
CDN_URL=https://cdn.nyumba360.co.ke

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_AI_FEATURES=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_SOCIAL_LOGIN=true
ENABLE_INTERNATIONAL_PAYMENTS=true

# =============================================================================
# BUSINESS CONFIGURATION
# =============================================================================
COMPANY_NAME=Nyumba360
COMPANY_EMAIL=info@nyumba360.co.ke
COMPANY_PHONE=+254700000000
COMPANY_ADDRESS=Nairobi, Kenya
DEFAULT_CURRENCY=KES
DEFAULT_LANGUAGE=en
TIMEZONE=Africa/Nairobi
DATE_FORMAT=YYYY-MM-DD

# =============================================================================
# COMMISSION RATES
# =============================================================================
AGENT_COMMISSION_RATE=0.10
PROPERTY_MANAGER_COMMISSION_RATE=0.05

# =============================================================================
# LEGAL CONFIGURATION
# =============================================================================
PRIVACY_POLICY_URL=https://nyumba360.co.ke/privacy
TERMS_OF_SERVICE_URL=https://nyumba360.co.ke/terms
DATA_RETENTION_DAYS=365
COOKIE_CONSENT_REQUIRED=true

# =============================================================================
# MAINTENANCE CONFIGURATION
# =============================================================================
MAINTENANCE_ALERT_EMAIL=maintenance@nyumba360.co.ke
MAINTENANCE_ALERT_PHONE=+254700000000
MAINTENANCE_WINDOW_START=02:00
MAINTENANCE_WINDOW_END=04:00

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
DOCKER_ENVIRONMENT=production
DOCKER_NETWORK=nyumba360-network-prod
BACKEND_CONTAINER=nyumba360-backend-prod
FRONTEND_CONTAINER=nyumba360-frontend-prod
MOBILE_CONTAINER=nyumba360-mobile-prod
DATABASE_CONTAINER=nyumba360-database-prod
