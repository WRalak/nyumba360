# =============================================================================
# NYUMBA360 ENVIRONMENT VARIABLES - DEVELOPMENT
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=5001
HOST=localhost

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/nyumba360_dev
DB_NAME=nyumba360_dev
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT=10000

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET=nyumba360_jwt_secret_key_development_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# =============================================================================
# M-PESA DARAJA API CONFIGURATION
# =============================================================================
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here
MPESA_PASSKEY=your_mpesa_passkey_here
MPESA_SHORTCODE=174379

# M-Pesa Callback URLs
MPESA_CALLBACK_URL=http://localhost:5001/api/payments/mpesa/callback
MPESA_RESULT_URL=http://localhost:5001/api/payments/mpesa/result
MPESA_QUEUE_TIMEOUT_URL=http://localhost:5001/api/payments/mpesa/timeout
MPESA_ENVIRONMENT=sandbox

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@nyumba360.co.ke
EMAIL_FROM_NAME=Nyumba360

# =============================================================================
# SMS CONFIGURATION
# =============================================================================
AFRICASTALKING_USERNAME=your_africastalking_username_here
AFRICASTALKING_API_KEY=your_africastalking_api_key_here
AFRICASTALKING_SENDER=Nyumba360

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:19006
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=nyumba360_session_secret_development_2024
SESSION_MAX_AGE=86400000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
REACT_APP_API_URL=http://localhost:5001/api
REACT_APP_MOCK_API=false
REACT_APP_ENVIRONMENT=development
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =============================================================================
# MOBILE APP CONFIGURATION
# =============================================================================
EXPO_PUBLIC_API_URL=http://localhost:5001/api
EXPO_PUBLIC_MOCK_API=false
EXPO_PUSH_NOTIFICATION_KEY=your_expo_push_key_here

# =============================================================================
# AI CONFIGURATION
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
ML_MODEL_PATH=./models
ML_CONFIDENCE_THRESHOLD=0.8

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_AI_FEATURES=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_INTERNATIONAL_PAYMENTS=false

# =============================================================================
# BUSINESS CONFIGURATION
# =============================================================================
COMPANY_NAME=Nyumba360
COMPANY_EMAIL=info@nyumba360.co.ke
COMPANY_PHONE=+254700000000
COMPANY_ADDRESS=Nairobi, Kenya
DEFAULT_CURRENCY=KES
DEFAULT_LANGUAGE=en
TIMEZONE=Africa/Nairobi
DATE_FORMAT=YYYY-MM-DD

# =============================================================================
# COMMISSION RATES
# =============================================================================
AGENT_COMMISSION_RATE=0.10
PROPERTY_MANAGER_COMMISSION_RATE=0.05

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
TEST_DATABASE_URL=mongodb://localhost:27017/nyumba360_test
TEST_JWT_SECRET=test_jwt_secret
TEST_EMAIL_SERVICE=mock

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
DEBUG=nyumba360:*
HOT_RELOAD=true
MOCK_DATA=true
