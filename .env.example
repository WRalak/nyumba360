# =============================================================================
# NYUMBA360 ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and update with your actual values
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=5001
HOST=localhost

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/nyumba360_dev

# MongoDB Atlas (for production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nyumba360_prod

# Database Options
DB_NAME=nyumba360_dev
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT=10000

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# JWT Secret Key (use a strong, random string in production)
JWT_SECRET=your_super_secure_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# =============================================================================
# M-PESA DARAJA API CONFIGURATION
# =============================================================================
# Get these from Safaricom Developer Portal: https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=174379

# M-Pesa Callback URLs
MPESA_CALLBACK_URL=http://localhost:5001/api/payments/mpesa/callback
MPESA_RESULT_URL=http://localhost:5001/api/payments/mpesa/result
MPESA_QUEUE_TIMEOUT_URL=http://localhost:5001/api/payments/mpesa/timeout

# M-Pesa Environment (sandbox or live)
MPESA_ENVIRONMENT=sandbox

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# SendGrid (recommended)
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@nyumba360.co.ke
EMAIL_FROM_NAME=Nyumba360

# Alternative: SMTP Configuration
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# =============================================================================
# SMS CONFIGURATION
# =============================================================================
# Africa's Talking SMS Service
AFRICASTALKING_USERNAME=your_africastalking_username
AFRICASTALKING_API_KEY=your_africastalking_api_key
AFRICASTALKING_SENDER=Nyumba360

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
# Upload Directory
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# AWS S3 (for production file storage)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=nyumba360-uploads

# =============================================================================
# REDIS CONFIGURATION (for caching and sessions)
# =============================================================================
# Redis Connection (optional but recommended for production)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your_session_secret_key
SESSION_MAX_AGE=86400000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Log File Path
LOG_FILE=./logs/app.log

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
# New Relic (for application monitoring)
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
NEW_RELIC_APP_NAME=Nyumba360

# Sentry (for error tracking)
SENTRY_DSN=your_sentry_dsn

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# React App URL
REACT_APP_API_URL=http://localhost:5001/api
REACT_APP_MOCK_API=false
REACT_APP_ENVIRONMENT=development

# Google Maps API (for property location)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# =============================================================================
# MOBILE APP CONFIGURATION
# =============================================================================
# Expo Configuration
EXPO_PUBLIC_API_URL=http://localhost:5001/api
EXPO_PUBLIC_MOCK_API=false

# Push Notifications
EXPO_PUSH_NOTIFICATION_KEY=your_expo_push_key

# =============================================================================
# AI CONFIGURATION
# =============================================================================
# OpenAI API (for advanced AI features)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo

# Machine Learning Models
ML_MODEL_PATH=./models
ML_CONFIDENCE_THRESHOLD=0.8

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION
# =============================================================================
# Stripe (for international payments)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# PayPal (alternative payment method)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# =============================================================================
# SOCIAL LOGIN CONFIGURATION
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# =============================================================================
# ANALYTICS CONFIGURATION
# =============================================================================
# Google Analytics
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Mixpanel Analytics
MIXPANEL_TOKEN=your_mixpanel_token

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# Database Backup
BACKUP_SCHEDULE=0 2 * * *
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# Cloud Storage Backup
# BACKUP_PROVIDER=aws_s3
# BACKUP_BUCKET=nyumba360-backups

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Enable Debug Mode
DEBUG=nyumba360:*

# Enable Hot Reload
HOT_RELOAD=true

# Mock Data
MOCK_DATA=true

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================
# SSL Configuration (for production)
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# Domain Configuration
DOMAIN=nyumba360.co.ke
PROTOCOL=https

# CDN Configuration
CDN_URL=https://cdn.nyumba360.co.ke

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
# Test Database
TEST_DATABASE_URL=mongodb://localhost:27017/nyumba360_test

# Test Environment Variables
TEST_JWT_SECRET=test_jwt_secret
TEST_EMAIL_SERVICE=mock

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/Disable Features
ENABLE_AI_FEATURES=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_INTERNATIONAL_PAYMENTS=false

# =============================================================================
# BUSINESS CONFIGURATION
# =============================================================================
# Company Information
COMPANY_NAME=Nyumba360
COMPANY_EMAIL=info@nyumba360.co.ke
COMPANY_PHONE=+254700000000
COMPANY_ADDRESS=Nairobi, Kenya

# Business Rules
DEFAULT_CURRENCY=KES
DEFAULT_LANGUAGE=en
TIMEZONE=Africa/Nairobi
DATE_FORMAT=YYYY-MM-DD

# Commission Rates
AGENT_COMMISSION_RATE=0.10
PROPERTY_MANAGER_COMMISSION_RATE=0.05

# =============================================================================
# MAINTENANCE CONFIGURATION
# =============================================================================
# Maintenance Alerts
MAINTENANCE_ALERT_EMAIL=maintenance@nyumba360.co.ke
MAINTENANCE_ALERT_PHONE=+254700000000

# Scheduled Maintenance
MAINTENANCE_WINDOW_START=02:00
MAINTENANCE_WINDOW_END=04:00

# =============================================================================
# LEGAL CONFIGURATION
# =============================================================================
# Privacy Policy
PRIVACY_POLICY_URL=https://nyumba360.co.ke/privacy
TERMS_OF_SERVICE_URL=https://nyumba360.co.ke/terms

# Compliance
DATA_RETENTION_DAYS=365
COOKIE_CONSENT_REQUIRED=true

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
# Docker Environment
DOCKER_ENVIRONMENT=development
DOCKER_NETWORK=nyumba360-network

# Container Names
BACKEND_CONTAINER=nyumba360-backend
FRONTEND_CONTAINER=nyumba360-frontend
MOBILE_CONTAINER=nyumba360-mobile
DATABASE_CONTAINER=nyumba360-database

# =============================================================================
# NOTES
# =============================================================================
# 1. Replace all placeholder values with your actual configuration
# 2. Never commit .env file to version control
# 3. Use different values for development, staging, and production
# 4. Keep sensitive information secure and use environment-specific secrets
# 5. Regularly rotate API keys and secrets
# 6. Use strong, unique passwords for all services
# =============================================================================
